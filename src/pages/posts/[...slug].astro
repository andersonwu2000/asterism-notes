---
import Base from '../../layouts/Base.astro'
import PostTail from '../../components/PostTail.astro'
import Timeline from '../../components/Timeline.astro'
import { pairedPosts } from '../../lib/posts.mjs'

export async function getStaticPaths() {
  const posts = await pairedPosts()
  return posts
    .filter((p) => p.en)
    .map((p) => ({ params: { slug: p.slug }, props: { post: p } }))
}

const { post } = Astro.props
const posts = await pairedPosts()
const { Content } = await post.en.render()
const base = import.meta.env.BASE_URL
const when = post.en.data.date.toISOString().slice(0, 10)
---

<Base
  title={post.en.data.title}
  description={post.en.data.description}
  lang="en"
  alt={post.zh ? `${base}zh/posts/${post.slug}/` : null}
  ogType="article"
  footerEmail={false}
>
  <Timeline posts={posts} current={post.slug} lang="en" />
  <article class="post">
    <header>
      <div class="meta">
        <span>{when}</span>
      </div>
      <h1>{post.en.data.title}</h1>
    </header>
    <div class="prose">
      <Content />
    </div>
    <PostTail lang="en" />
  </article>
</Base>
