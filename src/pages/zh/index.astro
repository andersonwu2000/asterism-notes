---
import Base from '../../layouts/Base.astro'
import { pairedPosts } from '../../lib/posts.mjs'

const posts = await pairedPosts()
const base = import.meta.env.BASE_URL
const fmt = (d: Date) => d.toISOString().slice(0, 10)
---

<Base lang="zh" alt={base}>
  <section class="preamble">
    <h1>Asterism Notes</h1>
    {/* one source line: an .astro template is NOT markdown — the CJK
        soft-break fix doesn't reach here, a wrapped line becomes a
        phantom space */}
    <p>Asterism 是一個讓 LLM agent 書寫機器驗證 Lean 證明的框架。這裡記錄它成形過程中的設計——信任邊界、調度機制、證明庫的維護。歡迎討論。</p>
  </section>
  <ul class="posts">
    {
      posts.map((p) => {
        const side = p.zh ?? p.en
        return (
          <li>
            <span class="when">{fmt(p.date)}</span>
            {!p.zh && <span class="lang">English</span>}
            <h2>
              <a
                href={
                  p.zh
                    ? `${base}zh/posts/${p.slug}/`
                    : `${base}posts/${p.slug}/`
                }
              >
                {side.data.title}
              </a>
            </h2>
            {side.data.description && <p class="desc">{side.data.description}</p>}
          </li>
        )
      })
    }
  </ul>
</Base>
