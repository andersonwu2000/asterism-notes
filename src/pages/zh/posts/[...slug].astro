---
import Base from '../../../layouts/Base.astro'
import PostTail from '../../../components/PostTail.astro'
import Timeline from '../../../components/Timeline.astro'
import { pairedPosts } from '../../../lib/posts.mjs'

export async function getStaticPaths() {
  const posts = await pairedPosts()
  return posts
    .filter((p) => p.zh)
    .map((p) => ({ params: { slug: p.slug }, props: { post: p } }))
}

const { post } = Astro.props
const posts = await pairedPosts()
const { Content } = await post.zh.render()
const base = import.meta.env.BASE_URL
const when = post.zh.data.date.toISOString().slice(0, 10)
const me = posts.find((p) => p.slug === post.slug)
const idx = posts.findIndex((p) => p.slug === post.slug)
const toNav = (p: any) =>
  p
    ? {
        no: p.no,
        title: (p.zh ?? p.en).data.title,
        href: p.zh ? `${base}zh/posts/${p.slug}/` : `${base}posts/${p.slug}/`,
      }
    : null
const newer = toNav(idx > 0 ? posts[idx - 1] : null)
const older = toNav(idx >= 0 && idx < posts.length - 1 ? posts[idx + 1] : null)
---

<Base
  title={post.zh.data.title}
  description={post.zh.data.description}
  lang="zh"
  alt={post.en ? `${base}posts/${post.slug}/` : null}
  ogType="article"
  footerEmail={false}
>
  <Timeline posts={posts} current={post.slug} lang="zh" />
  <article class="post" lang="zh-Hant">
    <header>
      <div class="meta">
        <span>№ {me?.no}</span>
        <span>{when}</span>
      </div>
      <h1>{post.zh.data.title}</h1>
    </header>
    <div class="prose">
      <Content />
    </div>
    <PostTail
      lang="zh"
      no={me?.no}
      title={post.zh.data.title}
      year={post.zh.data.date.getFullYear()}
      prev={older}
      next={newer}
    />
  </article>
</Base>
