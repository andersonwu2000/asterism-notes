---
import Base from '../layouts/Base.astro'
import { pairedPosts } from '../lib/posts.mjs'

const posts = await pairedPosts()
const base = import.meta.env.BASE_URL
const fmt = (d: Date) => d.toISOString().slice(0, 10)
---

<Base lang="en" alt={`${base}zh/`}>
  <section class="preamble">
    <h1>Notes on machine&#8209;checked mathematics, written&nbsp;while&nbsp;building&nbsp;it</h1>
    <p>
      Asterism is a framework in which LLM agents write machine-checked
      Lean proofs. These notes record its design as it is built — trust
      boundaries, dispatch machinery, keeping a growing proof library
      clean. Discussion is welcome.
    </p>
  </section>
  <ul class="posts">
    {
      posts.map((p) => (
        <li>
          <span class="when">{fmt(p.date)}</span>
          {!p.en && <span class="lang">中文</span>}
          <h2>
            <a
              href={
                p.en
                  ? `${base}posts/${p.slug}/`
                  : `${base}zh/posts/${p.slug}/`
              }
            >
              {p.title}
            </a>
          </h2>
          {p.description && <p class="desc">{p.description}</p>}
        </li>
      ))
    }
  </ul>
</Base>
