---
import Base from '../layouts/Base.astro'
import { pairedPosts } from '../lib/posts.mjs'

const posts = await pairedPosts()
const base = import.meta.env.BASE_URL
const fmt = (d: Date) =>
  d.toISOString().slice(0, 10)
---

<Base>
  <section class="preamble">
    <h1>Notes on machine&#8209;checked mathematics, written&nbsp;while&nbsp;building&nbsp;it</h1>
    <p>
      Asterism is a framework in which LLM agents write Lean proofs — and
      which tries to be precise about where its claims of correctness come
      from. These notes discuss its design as it takes shape: trust
      boundaries, the dispatch machinery, what it takes to keep a growing
      proof library clean.
    </p>
    <p>
      Nothing here is a grand claim; most of it is a working record.
      Corrections and discussion are welcome.
    </p>
  </section>
  <ul class="posts">
    {
      posts.map((p) => (
        <li>
          <span class="when">{fmt(p.date)}</span>
          {p.en && p.zh && (
            <a class="lang" href={`${base}zh/posts/${p.slug}/`}>
              中文
            </a>
          )}
          {!p.en && p.zh && <span class="lang">中文</span>}
          <h2>
            <a
              href={
                p.en
                  ? `${base}posts/${p.slug}/`
                  : `${base}zh/posts/${p.slug}/`
              }
            >
              {p.title}
            </a>
          </h2>
          {p.description && <p class="desc">{p.description}</p>}
        </li>
      ))
    }
  </ul>
</Base>
