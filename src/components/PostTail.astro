---
import { SITE } from '../site.config.mjs'

/*
 * Under every post: the contact line (owner call, 2026-07-13 — no
 * comment section; a mailbox is a kinder pace for disagreement).
 */
interface Props {
  lang?: 'en' | 'zh'
}
const { lang = 'en' } = Astro.props
---

{
  SITE.email && (
    <div class="post-tail">
      {lang === 'zh' ? (
        <>
          想法、指正、異議都歡迎：
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </>
      ) : (
        <>
          Thoughts, corrections, disagreements — all welcome:{' '}
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </>
      )}
    </div>
  )
}
