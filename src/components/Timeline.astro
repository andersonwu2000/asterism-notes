---
/*
 * The left-margin timeline (post pages, wide screens only): every
 * post as a small star on one vertical thread, the current one lit.
 * It lives in the space the reading column leaves empty and vanishes
 * the moment the viewport can't afford it — the text column never
 * pays for it.
 */
interface Props {
  posts: any[]
  current: string
  lang?: 'en' | 'zh'
}
const { posts, current, lang = 'en' } = Astro.props
const base = import.meta.env.BASE_URL
const href = (p: any) =>
  lang === 'zh'
    ? p.zh
      ? `${base}zh/posts/${p.slug}/`
      : `${base}posts/${p.slug}/`
    : p.en
      ? `${base}posts/${p.slug}/`
      : `${base}zh/posts/${p.slug}/`
const label = (p: any) =>
  (lang === 'zh' ? (p.zh ?? p.en) : (p.en ?? p.zh)).data.title
const fmt = (d: Date) => d.toISOString().slice(0, 10)
---

<aside class="timeline" aria-label={lang === 'zh' ? '所有文章' : 'all posts'}>
  <ol>
    {
      posts.map((p) => (
        <li class={p.slug === current ? 'now' : ''}>
          <a href={href(p)} title={label(p)}>
            <span class="t-dot" aria-hidden="true" />
            <span class="t-when">{fmt(p.date)}</span>
            <span class="t-title">{label(p)}</span>
          </a>
        </li>
      ))
    }
  </ol>
</aside>
