---
import '@fontsource/inter/400.css'
import '@fontsource/inter/500.css'
import '@fontsource/inter/600.css'
import '@fontsource/jetbrains-mono/400.css'
import '@fontsource-variable/fraunces'
import 'katex/dist/katex.min.css'
import '../styles/global.css'
import { SITE } from '../site.config.mjs'

interface Props {
  title?: string
  description?: string
  /** page language — sets <html lang> and the switcher's label */
  lang?: 'en' | 'zh'
  /** the SAME page in the other language; absent = no switcher */
  alt?: string | null
  /** 'article' on post pages, 'website' elsewhere */
  ogType?: string
  /** post pages carry their own contact line — skip the footer's */
  footerEmail?: boolean
}
const {
  title,
  description,
  lang = 'en',
  alt = null,
  ogType = 'website',
  footerEmail = true,
} = Astro.props
const base = import.meta.env.BASE_URL
const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title
const desc = description ?? SITE.description
const canonical = new URL(Astro.url.pathname, Astro.site).href
const altAbs = alt ? new URL(alt, Astro.site).href : null
/** the brand link goes HOME — in the reader's current language, not
 * silently back to English (cold-eye finding #2) */
const home = lang === 'zh' ? `${base}zh/` : base
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hant' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={ogType} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang === 'zh' ? 'zh-Hant' : 'en'} href={canonical} />
    {altAbs && (
      <link rel="alternate" hreflang={lang === 'zh' ? 'en' : 'zh-Hant'} href={altAbs} />
    )}
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={`${base}rss.xml`}
    />
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <nav>
          {/* the standard corner switcher: the OTHER language, named
              in its own script, pointing at the SAME page over there */}
          {alt && <a href={alt}>{lang === 'en' ? '中文' : 'English'}</a>}
          <a href={`${base}rss.xml`} title="subscribe — new posts land in your feed reader">RSS</a>
          {SITE.github && <a href={SITE.github}>GitHub</a>}
        </nav>
        <a class="brand" href={home}>
          {/* the mark IS an asterism: three stars, one line of sky */}
          <svg width="19" height="19" viewBox="0 0 20 20" aria-hidden="true">
            <path
              d="M4 14.5L10.5 5l5 6.5"
              stroke="currentColor"
              stroke-width="0.9"
              opacity="0.5"
              fill="none"
            />
            <circle cx="4" cy="14.5" r="1.7" fill="currentColor" />
            <circle cx="10.5" cy="5" r="2.1" fill="currentColor" />
            <circle cx="15.5" cy="11.5" r="1.4" fill="currentColor" />
          </svg>
          <span>{SITE.title}</span>
        </a>
      </header>
      <slot />
      <footer class="site">
        <span>{SITE.title}</span>
        <a href={`${base}rss.xml`} title="subscribe — new posts land in your feed reader">RSS</a>
        {SITE.github && <a href={SITE.github}>GitHub</a>}
        {footerEmail && SITE.email && (
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        )}
      </footer>
    </div>
  </body>
</html>
